#!/usr/bin/perl -w

use strict; use warnings; use 5.8.8; use autodie;
no strict 'refs';

use POSIX qw/strftime/;
my $date = strftime("%Y-%m-%d", localtime());
my $time = strftime("%H:%M:%S", localtime());


sub jobs_report_FA {
my $FILE = "/apps/meoatlas2/arnaud/jobs_error.txt_PL";
#system("autorep -j ALL | awk '$0 ~/\<FA\>/' > ${FILE}");
#system("autorep -j ALL | grep -w FA > ${FILE}");
#only the jobs
my @toto = qx{autorep -j ALL -L0 | grep -w FA | awk '{print \$1}' | awk 1 ORS='|' | awk '1' RS='|\n'};
#my $toto = qx{autorep -j ALL -L0 | grep -w FA | awk '{print \$1}' | awk 1 ORS='|' | awk '1' RS='|\n'};
#printf $toto;
qx{autorep -j ALL | grep -w FA | grep -v BOX > ${FILE}};
#qx{cat ${FILE} | grep -v $toto};

#my @list= grep {-v} @toto;

foreach my $truc (@toto) {
   print $truc;
}

qx{perl -ni -e 'print unless /@toto/;' ${FILE}};

#qx{cat ${FILE} | grep -v @list};

}

& jobs_report_FA;

