>/tmp/track.tmp
cautil select tjobset id=* runstat=OPHELD list |grep -E "Jobset:|Status|Qual" |grep -v Actual >/tmp/ttrk
cautil select tjob id=*,*,* runstat=ABORT list |grep -E "Jobset:|Job:|Status|Jno:" |grep -vE  "Ac" >>/tmp/ttrk
