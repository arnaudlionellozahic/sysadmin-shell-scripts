while read a1 a2 a3 a4 a5
do
case $a1 in
        Jobset:)
        J=1
        export var1=$a2
        ;;

        Job:)
        J=2
        export var5=$a2
        ;;

        Qualifier:)
        export var2=$a2
        ;;

        Jno:)
        export var2=$a4
        export var6=$a2
        ;;

        Run)

        export var3=$a3

        if [[  $J = 2 ]] then
        #if [[  $qualjob != $var2 ]] then
        var4=$(cautil list job id=$var1,$var5,$var6 |grep Description:|cut -f 2 -d :)
        echo  "        " $var1 " " $var5 "$zblanc" $var2 "$zblanc" $var6 "$zblanc" $var3 "$zblanc"  $var4 >>/tmp/track.tmp
        # fi
        else
        # if [[  $qualjb != $var2 ]] then
        var4=$(cautil list jobset id=$var1 |grep Description:|cut -f 2 -d :)
        #echo  "        " $var1 " " $var5 "$zblanc" $var2 "$zblanc" $var6 "$zblanc" $var3 "$zblanc"  $var4 >>/tmp/track.tmp
        echo  "        " $var1  "$zblanc "  "$zblanc" $var2 "$zblanc" $var6 "$zblanc     " $var3 "$zblanc"  $var4 >>/tmp/track.tmp
        # fi
        fi

        #echo  "        " $var1 " " $var5 "$zblanc" $var2 "$zblanc" $var6 "$zblanc" $var3 "$zblanc"  $var4 >>/tmp/track.tmp
        var1=""
        var2=""
        var3=""
        var4=""
        var5=""
        var6=""

        ;;
esac

done </tmp/ttrk

