                        #echo "</td>" >> ${FIC_HTML}
                        #echo "<td>" >> ${FIC_HTML}
                        #echo "$(echo ${line} | awk -F";" '{print $1}' |  awk -F"_" '{print $2}'| cut -c2-)" >> ${FIC_HTML}
                        #echo "</td>" >> ${FIC_HTML}
