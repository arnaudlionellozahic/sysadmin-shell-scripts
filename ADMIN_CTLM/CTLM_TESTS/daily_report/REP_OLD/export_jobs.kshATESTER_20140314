        echo "<tr bgcolor="#696969">" >> ${FIC_HTML}
        echo "<td>" >> ${FIC_HTML}
        echo "<b><center>EXPORT DES ERREURS CONTROL-M</center></b>" >> ${FIC_HTML}
        echo "</td>" >> ${FIC_HTML}
        echo "</tr>" >> ${FIC_HTML}
        cat ${out} | while read line
        do
                        echo "<tr bgcolor="#FFFFFF">" >> ${FIC_HTML}
                        echo "<td>" >> ${FIC_HTML}
