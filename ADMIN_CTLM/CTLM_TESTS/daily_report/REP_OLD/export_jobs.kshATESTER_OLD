#!/bin/ksh -x

mail ()
{
if [ `/bin/grep P $out | wc -l` -lt 1 ]
        then
                echo -e "\033[31mPas de traitements et groupes en erreur, holdes ou en attente de ressources\033[00m"
                echo "Pas de traitements et groupes en erreur, holdes ou en attente de ressources" > $out
                mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}] : Liste des traitements et groupes en erreur ou en hold entre le ${J_DAY} et le ${J_DAY2}" arnaud.lozahic-ext@natixis.com < ${FIC_HTML}
                exit 1
        else
mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}] : Liste des traitements et groupes en erreur ou en hold entre le ${J_DAY2} et le ${J_DAY}" arnaud.lozahic-ext@natixis.com -a ${FIC_HTML}
fi
}

fonc_rapport ()
{
        echo "<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0 Transitional//EN">" >> ${FIC_HTML}
        echo "<html><head><title>Recapitulatif des reorgs pour le WE </title>" >> ${FIC_HTML}
        echo "<meta http-equiv="Content-Type" content="text/html\;charset=windows-1252">" >> ${FIC_HTML}
        echo "<meta content="MSHTML 6.00.2900.3157" name="GENERATOR"></head>" >> ${FIC_HTML}
        echo "<body>" >> ${FIC_HTML}
        echo "<br>" >> ${FIC_HTML}
        echo "<table border=0 align="middle" bgcolor="#CCFFFF" width="60%">" >> ${FIC_HTML}
        echo "<tr bgcolor="#C0C0C0">" >> ${FIC_HTML}
        echo "<td>" >> ${FIC_HTML}
        echo "<b>APPLI</b>" >> ${FIC_HTML}
        echo "</td>" >> ${FIC_HTML}
        echo "<td>" >> ${FIC_HTML}
        echo "<b>TYPE</b>" >> ${FIC_HTML}
        echo "</td>" >> ${FIC_HTML}
        echo "<td>" >> ${FIC_HTML}
        echo "<b>CHAINE</b>" >> ${FIC_HTML}
        echo "</td>" >> ${FIC_HTML}
        echo "</tr>" >> ${FIC_HTML}
        cat ${out} | while read line
        do
                        echo "<tr bgcolor="#FFFFFF">" >> ${FIC_HTML}
                        echo "<td>" >> ${FIC_HTML}
                        echo "$(echo ${line} | awk -F";" '{print $1}'| cut -c2-3)" >> ${FIC_HTML}
                        echo "</td>" >> ${FIC_HTML}
                        echo "<td>" >> ${FIC_HTML}
                        echo "$(echo ${line} | awk -F";" '{print $1}' |  awk -F"_" '{print $2}'| cut -c2-)" >> ${FIC_HTML}
                        echo "</td>" >> ${FIC_HTML}
                        echo "<td>" >> ${FIC_HTML}
                        echo "$(echo ${line} | awk -F";" '{print $1}')" >> ${FIC_HTML}
                        echo "</td>" >> ${FIC_HTML}
                        echo "</tr>" >> ${FIC_HTML}
        done

        echo "</table>" >> ${FIC_HTML}
        echo "<p><hr><b>" >> ${FIC_HTML}
        echo "Pour un changement de planification, veuillez utiliser l'outils de gestion des purges/reorgs disponible sur <a href="http://web-ibo.smt.cib.net/mother/rapport_rri.php">mother</a>" >>${FIC_HTML}
        echo "</b><hr></p>" >> ${FIC_HTML}
        echo "<br>" >> ${FIC_HTML}
        echo "</body>" >> ${FIC_HTML}
        echo "</html>" >> ${FIC_HTML}
}


