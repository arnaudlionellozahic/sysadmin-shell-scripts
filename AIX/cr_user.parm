# Fichier parametre du script cr_user.ksh
# le separateur de champ est : (comme /etc/passwd)
# premier champ le nom du user
# deuxieme champ l'UID du user
# troisieme champ le group primaire du user
# quatrieme champ le commentaire
# sixieme champ la home dir du user (si blanc => /home/logname)
# septieme champ le shell
#
#
# exemple :
#toto:007:20:utilisateur toto:/tmp/toto:/usr/bin/ksh
iscope81:265:205:Admin Introscope:/home/iscope81:/bin/ksh
