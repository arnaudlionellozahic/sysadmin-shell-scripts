  <AUTOEDIT2 NAME="%%APPLI" VALUE="x6a"/>



  <AUTOEDIT2 NAME="%%GEIENV" VALUE="p"/>



  <AUTOEDIT2 NAME="%%PATHNAME" VALUE="/%%NODEID/appli/%%APPLI/%%APPLGROUP/travaux"/>



  <RULE_BASED_CALENDAR 

   APR="1" 

   AUG="1" 

   DAYS_AND_OR="OR" 

   DEC="1" 

   FEB="1" 

   JAN="1" 

   JUL="1" 

   JUN="1" 

