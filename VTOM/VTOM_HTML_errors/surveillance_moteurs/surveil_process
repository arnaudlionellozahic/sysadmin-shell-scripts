# echo "----------------------------------------------------------" >> $FIC_LOG
#else
# nb_sunopsis_serv1=$( ps -ef | grep sunopsis | grep -v java | grep -v grep | wc -l)
# echo "Serveur $serv1    $SERV1    $nb_sunopsis_serv1   process sunopsis " >> $FIC_LOG
# echo "-----------------------------------------------------------" >> $FIC_LOG
#fi







echo   "   RECETTE " $(date +%d-%m-%y\ %Hh%M) >> $FIC_LOG

}


# programme principal
clear
echo   "   PROD " $(date +%d-%m-%y\ %Hh%M)
echo   "   PROD " $(date +%d-%m-%y\ %Hh%M) >> $FIC_LOG
echo "----------------------------------------------------------" >> $FIC_LOG

