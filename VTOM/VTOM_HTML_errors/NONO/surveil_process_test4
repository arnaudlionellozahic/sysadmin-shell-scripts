# df -k avec tri decroissant sur le % d'occupation

df -h  | printf "%-30s %+10s %+10s %+10s %+3s %s %-3s\n" $(cut -f1) $(cut -f2) $(cut -f3) $(cut -f4) $(cut -f5) $(cut -f6) 

df -h | awk 'BEGIN {
      deb="" }
       length($0)<35 { deb=$1 ; printf "%-s ",$deb }
       length($0)>35 { printf "%s\n",$0 }           
      '|grep -v on | sort -n | printf "%-30s %+10s %+10s %+10s %+3s %-30s \n" $(cut -f1) $(cut -f2) $(cut -f3) $(cut -f4) $(cut -f5) $(cut -f6) 


