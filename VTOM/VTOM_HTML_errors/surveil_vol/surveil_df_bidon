# df -k avec tri decroissant sur le % d'occupation

function DF 
{
df -h | grep -v on | grep -v tmpfs | printf "%-30s %+15s %+15s %+15s %+10s %+10s \n" $(cut -f1)
}

DF | egrep '100%|9[0-9]%|8[0-9]%|7[0-9]%|6[0-9]%|2[0-9]%' > /exploit/systeme/suivi/TEST/surveil_df.log 

if [ `/bin/grep dev /exploit/systeme/suivi/TEST/surveil_df.log | wc -l` -ne 0 ]
then
	/bin/mailx -s "Espace fs > 60% : RECETTE COQEXPL1" arnaud.lozahic@mondial-assistance.fr < /exploit/systeme/suivi/TEST/surveil_df.log 
fi
