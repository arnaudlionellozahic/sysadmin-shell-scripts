fonc_execproc ()
{
echo   "*--------------------------------------------------*"
echo   "* Execution de la PS $1                             "
echo   "*--------------------------------------------------*"
>$ISQL_OUT

isql -S$SERVER -U$USER -P$PASS -s" " -w8000 <<EOF 1>$ISQL_OUT 2>&1

go

use $BASE
go


Declare @syb_err     Int,
        @syb_lib     VarChar(255)

EXECUTE $1 @syb_err OUTPUT, @syb_lib OUTPUT

select "RET_SYB:" + Convert(VarChar(10),@syb_err) + ":"
select "LIB_SYB:" + @syb_lib + ":"
go
EOF

CODE=$?
if [ $CODE -ne 0 ]
then
  echo "Code retour $CODE <> zero sur la PS $1"
  cat $ISQL_OUT
  exit 254
fi



egrep "Msg|error" $ISQL_OUT 2>/dev/null
if [ $? -eq 0 ]
then
    echo "ERREUR detectee par grep sur trace du fichier de sortie."
    cat $ISQL_OUT
    exit 254
fi

RET_SYB=`cat $ISQL_OUT | grep "RET_SYB" | \
 sed s/" "//g | awk -F":" '{print $2 }'`
LIB_SYB=`cat $ISQL_OUT | grep "LIB_SYB" | \
 awk -F":" '{print $2 }'`

echo "Retour sybase = $RET_SYB $LIB_SYB"

if [ $RET_SYB -ne 0 ]
then
    echo "\nCode retour $RET_SYB $RET_SYB <> zero sur PS $1"
    exit 254
else
 echo "*----------------*"
 echo "* ... Exec PS OK  "
 echo "*----------------*"
 return 0
fi
}

fonc_bcpin ()
{

echo "\n*------------------------------------------------------*"
echo   "*  Bcp in table $1 a partir de $2 avec le separateur $3 "
echo   "*------------------------------------------------------*"
>$BCPIN

bcp $BASE.dbo.$1 in $2 -S$SERVER -U$USER -P$PASS -b2000 -t$3 -m -X -c -e$BCPERR >$BCP 2>&1

CODE=$?
if [ $CODE -ne 0 ]
then
   echo "Code retour $CODE <> zero sur bcp in $1"
   cat $BCP
   exit 254
fi

cat $BCP | grep error > /dev/null 2>&1
if [ $? -eq 0 ]
then
        echo "Code retour > zero par grep error sur $1"
        cat $BCP
        exit 254
fi

cat $BCP | grep duplicate > /dev/null 2>&1
if [ $? -eq 0 ]
then
  echo "Code retour > zero par grep duplicate sur $1"
  cat $BCP
  exit 254
fi

echo "*------------------*"
echo "*... BCP OK                 "
echo "*------------------*"

}

fonc_truncate ()
{

echo "\n*--------------------------------------------------*"
echo   "* Truncate de la table $1                                                       "
echo   "*--------------------------------------------------*"

isql -S$SERVER -U$USER -P$PASS >$ISQL_OUT 2>&1 <<EOF
truncate table $BASE..$1
go

Select "Nb lignes apres truncate", Count (*) From $1
go
EOF

CODE=$?
if [ $CODE -ne 0 ]
then
    echo "Code retour $CODE <> zero sur truncate table $1"
    cat $ISQL_OUT
    exit 254
fi

grep Msg $ISQL_OUT >/dev/null 2>&1
if [ $? -eq 0 ]
  then
    echo "Erreur detectee par grep Msg"
    cat $ISQL_OUT
    exit 254
else
    echo "*------------------*"
    echo "*... Truncate OK   *"
    echo "*------------------*"
fi
}

fonc_GetAnomalies()
{
#$1=SEPARATOR
#$2=CODE TO SELECT LINES
echo "\n*--------------------------------------------------*" 
echo   "* Récupération des anomalies					" 
echo   "*--------------------------------------------------*" 

>$ISQL_OUT

isql -s"$1" -S$SERVER -U$USER -P$PASS  -w1800 <<EOF 1>$ISQL_OUT 2>&1
go
use $BASE
go
select 
	'$2',
	'BGCOLOR="'+
	case when type_rejet=1 then 
		'AntiqueWhite'
	else
		case when type_rejet=2 then 
			'BurlyWood'
		else
			case when type_rejet=3 then 
				'Darkorange'
			else
				case when type_rejet=4 then 
					'DodgerBlue'
				else
					case when type_rejet=5 then 
						'Gold'
					else
						case when type_rejet=6 then 
							'GreenYellow'
						else
							case when type_rejet=7 then 
								'Pink'
							else
								'LightSteelBlue'
							end
						end
					end
				end
			end
		end
	end
	+'"ENDCOLOR',
	case when mont.cod_montage is null then
		'---'
	else
		mont.cod_cat_asset
	end  as Categorie,
	ano.cod_appli as Application,
	ano.cod_contrat as Reference_Contrat, 
	--ano.cod_vers_mont as Version_Montage,
	ano.cod_montage as Id_Montage,
    ano.num_debt as Tranche,
	ano.motif_rejet as Motif_Rejet
from    
		ta_mont_amor_contrat_anomalie ano
		left join
		ta_mont_montage mont
		on 
		mont.cod_montage=ano.cod_montage
		and
        (
            
    		mont.cod_vers_mont=
            case when  dbo.fnc_GetMaxCodVersMont(mont.cod_montage) is null then
                mont.cod_vers_mont
            else
                dbo.fnc_GetMaxCodVersMont(mont.cod_montage)
            end
         )
where 
type_rejet>0 
and
type_rejet!=5 
order by type_rejet,cod_montage	,ano.cod_vers_mont

go

EOF

CODE=$?
if [ $CODE -ne 0 ]
then
    echo "Code retour $CODE <> zero sur Anomalies table ta_mont_amor_contrat_anomalie" 
    cat $ISQL_OUT
    exit 254
fi

egrep "Msg|error" $ISQL_OUT 2>/dev/null
if [ $? -eq 0 ]
  then
    echo "Erreur detectee par grep Msg"
    cat $ISQL_OUT
    exit 254
else
    echo "*------------------*" 
    echo "*... Anomalies OK   *"
    echo "*------------------*" 
fi
}



fonc_GetContratsIntegres ()
{
#$1=SEPARATOR
#$2=CODE TO SELECT LINES
echo "\n*--------------------------------------------------*" 
echo   "* Contrats Intégrés					" 
echo   "*--------------------------------------------------*" 

>$ISQL_OUT

isql -s"$1" -S$SERVER -U$USER -P$PASS  -w1800 <<EOF 1>$ISQL_OUT 2>&1
go
use $BASE
go
select 
	'$2',
	'BGCOLOR="'+
	case when type_rejet=1 then 
		'AntiqueWhite'
	else
		case when type_rejet=2 then 
			'BurlyWood'
		else
			case when type_rejet=3 then 
				'Darkorange'
			else
				case when type_rejet=4 then 
					'DodgerBlue'
				else
					case when type_rejet=5 then 
						'Gold'
					else
						case when type_rejet=6 then 
							'GreenYellow'
						else
							case when type_rejet=6 then 
								'Pink'
							else
								'LightSteelBlue'
							end
						end
					end
				end
			end
		end
	end
	+'"ENDCOLOR',
	mont.cod_cat_asset as Categorie,
	ano.cod_appli as Application,
	ano.cod_contrat as Reference_Contrat, 
	--ano.cod_vers_mont as Version_Montage,
	ano.cod_montage as Id_Montage,
    ano.num_debt as Tranche/*,
	ano.motif_rejet as Motif_Rejet*/
from    
		ta_mont_amor_contrat_anomalie ano
		inner join
		ta_mont_montage mont
		on 
		mont.cod_montage=ano.cod_montage
		and
		mont.cod_vers_mont=dbo.fnc_GetMaxCodVersMont(mont.cod_montage)
where 
type_rejet=0 
order by type_rejet,cod_montage

go

EOF

CODE=$?
if [ $CODE -ne 0 ]
then
    echo "Code retour $CODE <> zero sur Anomalies table ta_mont_amor_contrat_anomalie" 
    cat $ISQL_OUT
    exit 254
fi

grep Msg $ISQL_OUT >/dev/null 2>&1
if [ $? -eq 0 ]
  then
    echo "Erreur detectee par grep Msg"
    cat $ISQL_OUT
    exit 254
else
    echo "*------------------*" 
    echo "*... Contrats Intégrés OK   *"
    echo "*------------------*" 
fi
}
