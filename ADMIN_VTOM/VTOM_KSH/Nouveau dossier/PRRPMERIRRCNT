GetHtmlFile()
{
#$1=dest file
#$2=Source File
#$3=Separator
#$4=Code to select lines
	
	grep "$3$4" $2 | sed -e "s/^$3$4 *\($3\)/<TR STYLE=\"font-family: Times New Roman, Arial; font-size: 10pt\" WIDTH=\"100%\" BORDER=\"0.0\"/" \
		-e "s/$3BGCOLOR/ BGCOLOR/g" \
		-e "s/ENDCOLOR *\($3\)/><TD>/g" \
	    -e "s/$3/<\/TD><TD>/g" \
		-e "s/ *$/<\/TR>/g"            \
        -e "s/$3''/$3/g"          \
		-e "s/<TD><\/TR>/<\/TR><\/font>/g" \
		-e "s/$3//g" >> 	$1
		
	echo '</TABLE></HTML>' >> $1
}
