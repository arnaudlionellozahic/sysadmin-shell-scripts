#! /bin/ksh 
#__________________________________________________________
#
#     Demarrage des servers Visual TOM en mode securise
#          (relance automatique en cas de disparition du
#           processus vtsgbd ou bien vtserver)
#__________________________________________________________


ecrit_journal()
{

	msg=$1

	instant=`date '+%d-%m-%Y %H:%M:%S'`
	
	echo
	
	if [ $simulation -gt 0 ] ; then
		echo " -- SIMU --   "${msg}
		echo ${instant}" - SIMU - "${msg} >> ${journal}
		
	else
		echo " -- REEL --  "${msg}
		echo ${instant}" - REEL - "${msg} >> ${journal}		
	fi
	
}

cle_ficini()
{

	cle=$1
	valeur_defaut=$2
	
	valeur_cle=`grep "^${cle}:" ${fic_ini} | cut -d":" -f2-`
	
	if [ ! -z ${valeur_defaut} ] ; then
		if [ -z ${valeur_cle} ] ; then	
			valeur_cle=${valeur_defaut}
		fi
	fi
	
	echo ${valeur_cle}
	
}


collecte()
{

# ----- Collecte infos netstat, memoire et processus en cours

	ecrit_journal "Collecte netstat, vtping, top et ps"
	
	maintenant=`date '+%y%m%d_%H%M%S'`

	fic_collecte=${rep_collecte}/${maintenant}_netstat.txt
	uname -a > ${fic_collecte}
	echo "" >> ${fic_collecte}
	
	echo "netstat -a" >> ${fic_collecte}
	echo "----------" >> ${fic_collecte}
	echo "" >> ${fic_collecte}
	netstat -a >> ${fic_collecte}
	
	echo "" >> ${fic_collecte}
	echo "netstat -an">> ${fic_collecte}
	echo "-----------" >> ${fic_collecte}
	echo "" >> ${fic_collecte}
	netstat -an >> ${fic_collecte}

	fic_collecte=${rep_collecte}/${maintenant}_vtping_top.txt
	uname -a > ${fic_collecte}
	echo "" >> ${fic_collecte}

	echo "vtping" >> ${fic_collecte}
	echo "------" >> ${fic_collecte}
	echo "" >> ${fic_collecte}
	vtping >> ${fic_collecte}
	
	echo "" >> ${fic_collecte}	
	echo "top (${cde_top})" >> ${fic_collecte}
	echo "---" >> ${fic_collecte}
	echo "" >> ${fic_collecte}
	eval ${cde_top} ${cde_top_out} ${fic_collecte}
	
	echo "" >> ${fic_collecte}
	echo "ps avec vsz (${cde_ps_vsz})" >> ${fic_collecte}
	echo "-----------" >> ${fic_collecte}
	echo "" >> ${fic_collecte}
	eval ${cde_ps_vsz} >> ${fic_collecte}	
	
	fic_collecte=${rep_collecte}/${maintenant}_ps.txt
	uname -a > ${fic_collecte}
	echo "" >> ${fic_collecte}
	
	echo "Lise des processus (ps -ef)" >> ${fic_collecte}
	echo "------------------" >> ${fic_collecte}
	echo "" >> ${fic_collecte}
	ps -ef >> ${fic_collecte}
}

ensure()
{
	pid=$1
	name=$2

	if [ -n "`${cde_ps} | grep ${pid} | grep ${name}`" ] ; then
#COMmksnt	if [ -n "`${cde_ps} | grep ${pid}`" ] ; then
	
	
		export pid
		return $pid
	fi
	
        if [ "${name}" = "${serveur_vtom}" ] ; then

		ecrit_journal "Processus ${serveur_vtom} absent"

        	# ----- si vtsgbd absent, inutile de redemarrer vtserver. On sort.
        	#       La collecte netstat, top et ps sera faite dans ensure vtsgbd

		if [ -z "`${cde_ps} | grep ${pid_srv_base} | grep ${serveur_base}`" ] ; then
#COMmksnt		if [ -z "`${cde_ps} | grep ${pid_srv_base}`" ] ; then
			ecrit_journal "Processus ${serveur_base} absent. On sort"
			export pid
			return $pid
		fi
		
		# ----- Collecte netstat, top, ps
		
		if [ ${collecter} -gt 0 ] ; then
			collecte
		fi
		
		collecter=1
		export collecter
		
		# ----- on stocke la liste des moteurs allumes        

		find ${TOM_BASES} -name "*.pid" -exec basename {} \; | grep -v "postmaster" > ${rep_collecte}/lma.txt 2>/dev/null
		
		# ----- Archivage traces vtserver et vtsgbd

		archive=${rep_collecte}/${maintenant}_traces_serveurs.tar
		
		ecrit_journal "Archivage traces serveurs dans $archive"
		tar cf ${archive} ${rep_trc_serveurs}/vtserver.log ${rep_trc_serveurs}/vtserver.log.1 ${rep_trc_serveurs}/vtsgbd.log ${rep_trc_serveurs}/vtsgbd.log > /dev/null 2>&1
		
		ecrit_journal "Compression du fichier archive"
		sleep 2 ; compress ${archive} > /dev/null 2>&1
	
		# ----- Archivage bases
		#       vtserver etant potentiellement tombe, on ne peut pas utiliser vtbackup		
		
		archive=${rep_collecte}/${maintenant}_bases.tar
	
		ecrit_journal "Archivage base dans $archive"
		tar cf ${archive} ${TOM_BASES} > /dev/null 2>&1
		
		ecrit_journal "Compression du fichier archive"
		sleep 2 ; compress ${archive} > /dev/null 2>&1

		# ----- Lancement service		

		ecrit_journal "Redemarrage "${name}
		
#COMmksnt		sh ${TOM_BIN}/${name} > /dev/null &
		${TOM_BIN}/${name} > /dev/null &
		
		pid=$!
		

		# ----- Redemarrage des moteurs
		
		if [ -s ${rep_collecte}/lma.txt ] ; then
		
			# ----- on attend 2 min avant de démarrer les moteurs. En principe, il faudrait tester tlist env
			
			if [ $simulation -gt 0 ] ; then
		
				ecrit_journal "Attente 2 minutes avant redemarrage des moteurs"
		
				sleep 120
			
			else
				ecrit_journal "Attente 2 minutes avant redemarrage des moteurs (FICTIF)"
		
				sleep 1
			
			fi
		
			maintenant=`date '+%y%m%d_%H%M%S'`

			for item in `cat ${rep_collecte}/lma.txt`
			do
				if [ ! -z "${item}" ] ; then
				
					moteur=`echo ${item}|cut -d"." -f1`				
					
					# ----- Archivage traces moteur si chemin specifie dans fichier ini
	
					if [ ! -z "${rep_trc_moteurs}" ] ; then
	
						if [ -f "${rep_trc_moteurs}/${moteur}.log" ] ; then
	
							archive=${rep_collecte}/${maintenant}_${moteur}.tar
							
							ecrit_journal "Archivage traces moteur environnement ${moteur} dans $archive"
							tar cf ${archive} ${rep_trc_moteurs}/${moteur}.log ${rep_trc_moteurs}/${moteur}.log.1 > /dev/null 2>&1
							
							ecrit_journal "Compression du fichier archive"
							sleep 2 ; compress ${archive} > /dev/null 2>&1
						fi
					fi
					
					if [ $simulation -gt 0 ] ; then
						ecrit_journal "Redemarrage moteur environnement ${moteur} (FICTIF)"
					else
						ecrit_journal "Redemarrage moteur environnement ${moteur}"		
						estart ${moteur}
						sleep 2
					fi
				fi
		
			done			
		else
			if [ $simulation -eq 0 ] ; then
				sleep 30
			fi
			ecrit_journal "Aucun moteur a redemarrer"
		fi
		
		# ----- Notification par mail
		if [ ! -z ${mail_dest} ] ; then
			if [ ! -z ${mail_serveur} ] ; then
			
				liste_destinataires="Notification par mail a $mail_dest"
				
				destinataires="-to ${mail_dest}"
				
				if [ ! -z ${mail_cc} ] ; then
					destinataires="${destinataires} -cc ${mail_cc}"
					liste_destinataires="${liste_destinataires} ; cc ${mail_cc}"
					
				fi
				if [ ! -z ${mail_ccc} ] ; then
					destinataires="${destinataires} -bcc ${mail_ccc}"
					
					liste_destinataires="${liste_destinataires} ; ccc ${mail_ccc}"
				fi
				
				ecrit_journal "$liste_destinataires"
				fic_extrait_journal=${rep_collecte}/extrait_${moi}_journal.txt
				
				echo "Extrait de $journal (100 dernieres lignes). Fichier complet en attachement." > $fic_extrait_journal
				tail -100 $journal >> $fic_extrait_journal
				
				tmail -se $mail_exp $destinataires -smtp $mail_serveur -port $mail_port -sub "VTOM - relance automatique des serveurs" -msgf $fic_extrait_journal -att $journal > /dev/null 2>&1
#COM				echo tmail -se $mail_exp $destinataires -smtp $mail_serveur -port $mail_port -sub "VTOM - relance automatique des serveurs" -msgf $fic_extrait_journal -att $journal >> $journal
			fi
		fi

		# ----- Postage ftp
		if [ ! -z ${ftp_serveur} ] ; then
			if [ ! -z ${ftp_user} ] ; then
				
				ecrit_journal "Envoi par ftp sur serveur $ftp_serveur"
ftp -nv <<__FINFTP__ > ${rep_collecte}/ftp.log 2>&1
open ${ftp_serveur}
user ${ftp_user} ${ftp_passwd}
lcd ${rep_collecte}
binary
prompt
cd incoming
mput ${maintenant}_*
bye
__FINFTP__
			fi
		fi

	else
		
		ecrit_journal "Processus ${serveur_base} absent"
		
		# ----- Collecte netstat, top, ps si pas déjŕ fait par ensure vtserver
		
		collecte
		
		# ----- inutile de collecter de nouveau des infos volatiles
		collecter=0
		export collecter

		
		# ----- si vtserver present, il faut l arreter

#COMmksnt	if [ ! -z "`${cde_ps} | grep ${pid_srv_vtom}`" ] ; then
		if [ ! -z "`${cde_ps} | grep ${pid_srv_vtom} | grep ${serveur_vtom}`" ] ; then
		
			if [ $simulation -gt 0 ] ; then
				ecrit_journal "Processus ${serveur_base} absent. ${serveur_vtom} present - on arrete ${serveur_vtom} pat vtdcs (FICTIF)"
			else
				ecrit_journal "Processus ${serveur_base} absent. ${serveur_vtom} present - on arrete ${serveur_vtom} par vtdcs"
	                        vtdcs -s
	                        sleep 2
                        fi
                fi
                
		# ----- absence du process vtsgbd mais il faut l'arreter proprement (processus Postgres encore vivants)
		
		if [ $simulation -gt 0 ] ; then
			ecrit_journal "Arret propre ${serveur_base} par vtdcs (FICTIF)"
		else
			ecrit_journal "Arret propre ${serveur_base} par vtdcs"
			vtdcs -d
			sleep 2
			
		fi
                
		# ----- Lancement service		                

		ecrit_journal "Redemarrage "${name}
	
		${TOM_BIN}/${name} > /dev/null &
#COMmksnt	sh ${TOM_BIN}/${name} > /dev/null &
		
		pid=$!
	fi

	export pid
	return $pid
}


