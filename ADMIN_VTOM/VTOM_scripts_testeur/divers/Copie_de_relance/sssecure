if [ -z "${rep_trc_serveurs}" ] ; then
	echo ""
	echo "Repertoire des traces serveurs (cle REP_TRC_SERVEURS) non defini. Sortie."
	echo ""
	exit
fi

if [ ! -d "${rep_trc_serveurs}" ] ; then
	echo ""
	echo "Repertoire des traces serveurs ${rep_trc_serveurs} inexistant. Sortie."
	echo ""
	exit
fi

rep_collecte=`cle_ficini "REP_COLLECTE"`

if [ ! -z "${rep_collecte}" ] ; then
	if [ ! -d "${rep_collecte}" ] ; then
		echo ""
		echo "Repertoire de destination des elements collectes ${rep_collecte} inexistant. Sortie."	
		echo ""
