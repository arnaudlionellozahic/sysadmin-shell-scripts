#!/bin/ksh 

function process_ori 
{ 
ssh $SERV  ps -ef |  awk '  $8 !~ /^[0-9]*:[0-9]*$/ {printf "%-10s;%-15s; %-70s\n","serv",$1,$8" "$9" "$10" "$11 } 
                            $8 ~ /^[0-9]*:[0-9]*$/ {printf "%-10s;%-15s; %-70s\n","serv",$1,$9" "$10" "$11" "$12 }' | sed "s/serv/$SERV/g" | sort | grep -v UID | grep -v grep 
} 



