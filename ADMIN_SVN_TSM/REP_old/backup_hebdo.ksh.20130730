#!/bin/ksh -x 


backup ()
{
tar -pcf ${fic} svn_test

if [ $? == 0 ]
then
	echo "Bonjour," > ${out}
        echo "" >> ${out}
	echo "Le backup du repertoire ${rep} est OK le $(date +'%d/%m/%Y a %H:%M')" >> ${out}
	echo "" >> ${out}
	mv ${fic} ${rep_backup}
else 
	echo "Bonjour," > ${out}
        echo "" >> ${out}
	echo "Le backup du repertoire ${rep} est KO le $(date +'%d/%m/%Y a %H:%M')" >> ${out}
	mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}][SVN] - Le backup du repertoire ${rep} est KO le ${J_DAY}" arnaud.lozahic-ext@natixis.com < ${out}
   	exit 1 	
fi
}


tsm_ba ()

{
dsmc ba ${rep_backup}/${fic} -optfile=/opt/tivoli/tsm/client/ba/bin/BK/SLQDL7BDD01_BK-dsm.opt
}


tsm_q_ba ()

{
dsmc q ba ${rep_backup}/${fic} -optfile=/opt/tivoli/tsm/client/ba/bin/BK/SLQDL7BDD01_BK-dsm.opt > ${out2}

if [ `/bin/grep svn_pcf.tar ${out2} | wc -l` -lt 1 ]
then
        echo -e "\033[31mLa sauvegarde TSM est KO, veuillez verifier les logs ${out1} et ${out2}\033[00m"
	echo "Bonjour," > ${out}
	echo "" >> ${out}
        echo "La sauvegarde tsm est KO le $(date +'%d/%m/%Y a %H:%M'), veuillez consulter les logs ${out1} et ${out2}" >> ${out}
        mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}][SVN] - La sauvegarde incrementale est KO le ${J_DAY}" arnaud.lozahic-ext@natixis.com < ${out}
        exit 1
else
        echo -e "\033[31mLa sauvegarde TSM est OK\033[00m"
        echo "La sauvegarde TSM est OK le $(date +'%d/%m/%Y a %H:%M')" >> ${out}
        echo "" >> ${out}
        echo "-------------" >> ${out}
        echo "" >> ${out}
	sed -i -e '1,12d' ${out2} && sed -i -e '2d' ${out2}
	cat ${out2} | awk -F " " '{printf "%+10s %+15s %+10s %+15s\n", $1, $3, $4, $7}' | sed -e 's/Mgmt/Hour/g' > ${toto}
	cat ${toto} >> ${out}
        mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}][SVN] - Log de la sauvegarde incrementale du ${J_DAY}" arnaud.lozahic-ext@natixis.com < ${out}
fi
}


# Main
rep=/slqdl7bdd01/appli/svn
rep_backup=/slqdl7bdd01/appli/backup
rep_appli=/slqdl7bdd01/appli
fic=svn_pcf.tar
out=${rep_backup}/logs/tsm.log
out1=${rep_backup}/logs/tsm_ba.log
out2=${rep_backup}/logs/tsm_q_ba.log
toto=${rep_backup}/logs/toto.log
J_DAY=$(date "+%Y%m%d")
ENVI=PREX

cd ${rep_appli}
backup

cd ${rep_backup}
tsm_ba > ${out1}

tsm_q_ba

mail

rm -f ${rep_backup}/${fic} 
