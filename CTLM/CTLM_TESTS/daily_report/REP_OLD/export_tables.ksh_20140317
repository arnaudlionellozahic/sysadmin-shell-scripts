#!/bin/ksh -x


entete_error_J ()
{
echo "EXPORT_JOBS_DU_JOUR"
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en erreur sur le plan du ${J_DAY} : "
}

entete_hold_J ()
{
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en hold sur le plan du ${J_DAY} : "
}

entete_wait_res_J ()
{
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en attente de ressources sur le plan du ${J_DAY} : "
}


entete_error_J1 ()
{
echo "EXPORT_JOBS_DE_LA_VEILLE"
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en erreur sur le plan du ${J_DAY1} : "
}

entete_hold_J1 ()
{
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en hold sur le plan du ${J_DAY1} : "
}

entete_wait_res_J1 ()
{
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en attente de ressources sur le plan du ${J_DAY1} : "
}


entete_error_J2 ()
{
echo "EXPORT_JOBS_DE_L'AVANT_VEILLE"
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en erreur sur le plan du ${J_DAY2} : "
}

entete_hold_J2 ()
{
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en hold sur le plan du ${J_DAY2} : "
}

entete_wait_res_J2 ()
{
echo ""
echo "Vous trouverez ci-dessous la liste des traitements et groupes en attente de ressources sur le plan du ${J_DAY2} : "
}


req ()
{
for i in $list
do
ctmpsm -LISTALL | grep $i && echo $i
done
}

mail_mailx ()
{
if [ `/bin/grep P $out | wc -l` -lt 1 ]
        then
                echo -e "\033[31mPas de traitements et groupes en erreur, holdes ou en attente de ressources\033[00m"
                echo "Pas de traitements et groupes en erreur, holdes ou en attente de ressources" > $out
                mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}] : Liste des traitements et groupes en erreur ou en hold entre le ${J_DAY} et le ${J_DAY2}" arnaud.lozahic-ext@natixis.com < $out
                exit 1
        else
mailx -r mbx-tip-app-bfi-rri@natixis.com -s "[${ENVI}] : Liste des traitements et groupes en erreur ou en hold entre le ${J_DAY2} et le ${J_DAY}" arnaud.lozahic-ext@natixis.com < $out
fi
}

mail_sendmail ()
{
if [ `/bin/grep P $out | wc -l` -lt 1 ]
        then
                echo -e "\033[31mPas de traitements et groupes en erreur, holdes ou en attente de ressources\033[00m"
                echo "Pas de traitements et groupes en erreur, holdes ou en attente de ressources"
                FROM="bal-dsi-r2c-rpa-prr-pr2@natixis.com"
                MAILTO="arnaud.lozahic-ext@natixis.com"
                OBJET="[${ENVI}] : Liste des traitements et groupes en erreur ou en hold entre le ${J_DAY} et le ${J_DAY2}"
(
 echo "FROM: $FROM"
 echo "To: $MAILTO"
 echo "Subject: $OBJET"
 echo "MIME-Version: 1.0"
 echo "Importance: High"
 echo "Content-Type: text/plain"
 cat << EOF
Bonjour,

Il n'y a pas de traitements et groupes en erreur, holdes ou en attente de ressources sur pctrr.

Cordialement,
L'equipe Integration Resultats et Risques
EOF
) | /usr/sbin/sendmail -fbal-dsi-r2c-rpa-prr-pr2@natixis.com $MAILTO

        else

                FROM="bal-dsi-r2c-rpa-prr-pr2@natixis.com"
                MAILTO="arnaud.lozahic-ext@natixis.com"
                OBJET="[${ENVI}] : Liste des traitements et groupes en erreur ou en hold entre le ${J_DAY} et le ${J_DAY2}"
                export ATTACH="${out}"
(
 echo "FROM: $FROM"
 echo "To: $MAILTO"
 echo "Subject: $OBJET"
 echo "MIME-Version: 1.0"
 echo "Importance: High"
 echo 'Content-Disposition: attachment; filename="'$(basename $ATTACH)'"'
) | cat - ${ATTACH} | /usr/sbin/sendmail -fbal-dsi-r2c-rpa-prr-pr2@natixis.com -t $MAILTO

fi
}


#Main
rep=/slqdl7bdd01/appli/dl7/sp/tests_ctlm/daily_report
list=`cat ${rep}/liste_AJF.txt`
out=${rep}/export_error_$(date "+%Y%m%d").csv
out2=${rep}/export_temp.txt
J_DAY=$(date "+%Y%m%d")
J_DAY1=`TZ=MET+24 date "+%Y%m%d"`
J_DAY2=`date --date '2 days ago' "+%Y%m%d"`
ENVI=PREX
rapport_htlm=${rep}/export_jobs.kshATESTER

req > $out2

entete_error_J > $out
cat $out2 | grep TBL | grep NOTOK | grep ${J_DAY} | awk -F "|" '{print $2}' >> $out
entete_hold_J >> $out
cat $out2 | grep TBL | grep Hold | grep ${J_DAY} | awk -F "|" '{print $2}' >> $out
entete_wait_res_J >> $out
cat $out2 | grep TBL | grep "Wait Res" | grep ${J_DAY} | awk -F "|" '{print $2}' >> $out

echo "" >> $out
echo "_________________________________________________________________" >> $out
echo "" >> $out

entete_error_J1 >> $out
cat $out2 | grep TBL | grep NOTOK | grep ${J_DAY-1} | awk -F "|" '{print $2}' >> $out
entete_hold_J1 >> $out
cat $out2 | grep TBL | grep Hold | grep ${J_DAY-1} | awk -F "|" '{print $2}' >> $out
entete_wait_res_J1 >> $out
cat $out2 | grep TBL | grep "Wait Res" | grep ${J_DAY-1} | awk -F "|" '{print $2}' >> $out

echo "" >> $out
echo "_________________________________________________________________" >> $out
echo "" >> $out

entete_error_J2 >> $out
cat $out2 | grep TBL | grep NOTOK | grep ${J_DAY-2} | awk -F "|" '{print $2}' >> $out
entete_hold_J2 >> $out
cat $out2 | grep TBL | grep Hold | grep ${J_DAY-2} | awk -F "|" '{print $2}' >> $out
entete_wait_res_J2 >> $out
cat $out2 | grep TBL | grep "Wait Res" | grep ${J_DAY-2} | awk -F "|" '{print $2}' >> $out

rm -f $out2

ksh -x $rapport_htlm
