#fi

echo "#### FIN JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
#-------------------------------------------------------------------
# Fin du job proprement dit
#-------------------------------------------------------------------
if [ ${_CODE2} -ne 0 ]; then
        #echo "retour pour le chargement des donnees : ${_CODE2}"
        echo "exit ${_CODE2}"
        exit ${_CODE2}
                elif [ ${_CODE1} -ne 0 ]; then
                #echo "code retour du fichier vide ou non present : ${_CODE1}"
                echo "exit ${_CODE1}"
                exit ${_CODE1}
                        else
                        #echo "code retour : ${_CODE}"
                        echo "exit ${_CODE}"
                        exit ${_CODE}
fi
