sql_select ()
{

sqlplus -s /nolog <<EOF >/dev/null
connect $EXE_PARM

set linesize ${LINESIZE};
set termout off;
set newpage NONE;
set feed off;
spool ${_FIC_OUT};

set heading ${HEADING}
