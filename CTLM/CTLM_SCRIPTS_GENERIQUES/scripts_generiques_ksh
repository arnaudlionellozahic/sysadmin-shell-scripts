sql_before ()
{

sqlplus -s /nolog <<EOF > ${FILE_LOG}
connect $EXE_PARM

/* FERMAT BATCH - $DESC - Script generated on 06/10/2004 17:13:07 */
execute $PROC_BEFORE('20${ODATE}'); $PROC;
DELETE FROM CUST_PARAM_PARTITION WHERE PARAM_CODE = '${PARAM_CODE}';
INSERT INTO CUST_PARAM_PARTITION (PARAM_CODE, param_val) values ('${PARAM_CODE}', 'E');
COMMIT;
exit

quit
EOF
}


verif_apres_proc()
{
# ---------------------------------------------------------------------------- #
# Information sur le fichier de sortie (avant lancement de la procedure)
# ---------------------------------------------------------------------------- #
# On verifie existance du fichier genere
if [ -f ${FILE_LOG} ]; then
        echo "Information sur le repertoire ${REP_LOG}"
        echo "`ls -dl ${REP_LOG}`"
        echo ""
        echo "Information sur le fichier ${DESC}-${DATE}.log"
        echo "Le fichier ${FILE_LOG} existe et n'est pas vide"
        echo "`ls -ltr ${DESC}-${DATE}.log`"
                else
                echo "Information sur le repertoire ${REP_LOG}"
                echo "`ls -dl ${REP_LOG}`"
                echo ""
                echo "Information sur le fichier ${DESC}-${DATE}.log"
                echo "Le fichier ${FILE_LOG} est vide ou n'existe pas"
                echo "`ls -ltr ${DESC}-${DATE}.log`"
                echo ""
                echo "#### FIN JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
                echo "exit 1"
                exit 1
fi


# On verifie qu'il n'y a pas d'erreur ORACLE
if [ `/bin/grep ERROR ${FILE_LOG} | wc -l` -gt 0 ] || [ `/bin/grep SP2-0640 ${FILE_LOG} | wc -l` -gt 0 ]; then
  echo ""
  echo "PLANTAGE DE LA PROCEDURE AVEC L'ERREUR SUIVANTE : "
  echo ""
  echo "`cat ${FILE_LOG}`"
  echo "**********************************************************************************************************"
  echo ""
  echo "#### FIN JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
  echo "exit 2"
  exit 2
        else
        echo ""
        echo "**********************************************************************************************************"
        echo "PAS D'ERREUR DANS LE FICHIER ${FILE_LOG} DE LA PROCEDURE"
        echo "**********************************************************************************************************"
fi

}


