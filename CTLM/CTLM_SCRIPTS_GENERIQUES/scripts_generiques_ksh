IV) SCRIPT "SQLEXECUTE" - Lancement d'une procedure SQL (execute)
Les sources sont dans : /mscoutille/appli/q04/EXPLOIT/scripts
Ce script permet de lancer une procédure SQL. 

IV.1) VARIABLES CTLM DANS LE JOB 

Variables dans le job prenants les valeurs des variables du groupe ctlm : 
ODATE=${1}         correspond au 1er argument de la ligne de commande du job ctlm soit %%PARM1
PROC=${2}          correspond au 2nd argument de la ligne de commande du job ctlm soit %%PROC 
DESC=${3}          correspond au 3čme argument de la ligne de commande du job ctlm soit %%DESC
SQLE=${4}          correspond au 4čme argument de la ligne de commande du job ctlm soit %%SQLE 
REP=${5}           correspond au 5čme argument de la ligne de commande du job ctlm soit %%REP 
PROC_BEFORE=${6}   correspond au 6čme argument de la ligne de commande du job ctlm soit %%PROC_BEFORE 
CONTEXTE=${7}      correspond au 7čme argument de la ligne de commande du job ctlm soit %%CONTEXTE 

La ligne de commande est la suivante : 
/%%NODEID/appli/%%APPLI/EXPLOIT/scripts/SQLEXECUTE %%PARM1 %%PROC %%DESC %%SQLE %%REP %%PROC_BEFORE %%CONTEXTE

IV.1.a) Description des VARIABLES CTLM 

-> Variables génériques sur le groupe
%%PARM1           a pour valeur %%ODATE : la date du plan au format yymmaa
%%REP             a pour valeur "/%%NODEID/appli/%%APPLI/%%APPLGROUP"
%%SQLE            a pour valeur "sql_execute"

-> Variables génériques sur le job
%%PROC            a pour valeur le nom de la procédure ŕ exécuter ("PACK_CUST_PERTURBATIF.ALIM_TIERS_ABAQUE" dans mon exemple)
%%DESC            a pour valeur la description de la procedure ("alim_tiers_abaque" dans mon exemple)
%%PROC_BEFORE     a pour valeur "PACK_CUST_BATCH.BEFORE_LANCEMENT"
%%CONTEXTE        a pour valeur "O" ou "N"

IV.2) VARIABLES VALORISEES DANS LE SCRIPT
${GENERAL_ENV}    prend pour valeur le fichier env_q04.ksh global ŕ l'appli
${LOCAL_ENV}      prend pour valeur le fichier env.ksh local au groupe (s'il existe c'est ce dernier qui est prioritaire)
${REP_LOG}        prend pour valeur ${REP}/logs
${FILE_LOG}       prend pour valeur ${REP_LOG}/${DESC}-${DATE}.log

IV.3) FONCTIONNEMENT DU SCRIPT
La fonction sql_before exécute la procédure PACK_CUST_BATCH.BEFORE_LANCEMENT et la procédure sql si %%CONTEXTE est positionnée ŕ NON (N).
La fonction sql_execute exécute la procédure sql si %%CONTEXTE est positionnée ŕ NON (N).
La fonction verif_apres_proc donne des informations sur les fichiers de sortie (avant lancement de la procedure).

IV.4) LES CODES RETOUR
echo "exit ${?}"
exit ${?}

IV.5) SCRIPT 
#!/bin/ksh
# ----------------------------------------------------------------------------
# SQLEXECUTE : Lancement d'une procedure SQL (execute)
# ----------------------------------------------------------------------------
# Parametres     :
# Entrees        :
# Sorties        :
# ----------------------------------------------------------------------------
# ----------------------------------------------------------------------------

######################################################
# Diverses initialisations de variables obligatoires #
######################################################

# Parametres passes en arguments par CONTROL-M
ODATE=${1}
[ "X${ODATE}" = "X" ] && echo "Parm ODATE non specifie" && exit 1

PROC=${2}
[ "X${PROC}" = "X" ] && echo "Parm PROC non specifie" && exit 1

DESC=${3}
[ "X${DESC}" = "X" ] && echo "Parm DESC non specifie" && exit 1

SQLE=${4}
[ "X${SQLE}" = "X" ] && echo "Parm SQLE non specifie" && exit 1

REP=${5}
[ "X${REP}" = "X" ] && echo "Parm REP non specifie" && exit 1

PROC_BEFORE=${6}
[ "X${PROC_BEFORE}" = "X" ] && echo "Parm PROC_BEFORE non specifie" && exit 1

CONTEXTE=${7}
[ "X${CONTEXTE}" = "X" ] && echo "Parm CONTEXTE non specifie" && exit 1

# exporte les variables CTM0, GEHLOG, GEDAA, GEDAACC et GEDSOFT
ctrlmExports ${0}

# source l'environnement de la machine logique
switch ${GEHLOG} > /dev/null


############################################
# Chargement des variables d'environnement #
############################################

GENERAL_ENV="${GEDAA}/etc/`echo ${GEIENV} | tr "UQP" "uqp"`v/env_q04.ksh"
LOCAL_ENV="${REP}/`echo ${GEIENV} | tr "UQP" "uqp"`v/etc/env.ksh"

if [ -f ${GENERAL_ENV} ]; then
  . ${GENERAL_ENV}
  [ $? -ne 0 ] && MsgError "impossible de charger l'environnement" && exit 1
fi

if [ -f ${LOCAL_ENV} ]; then
  . ${LOCAL_ENV}
  [ $? -ne 0 ] && MsgError "impossible de charger l'environnement" && exit 1
fi

#############################################################
# Initialisation des variables n'ayant pas a etre modifiees #
#############################################################

DATE=`date +"%Y%m%d_%H%M%S"`

###################################################
# Initialisation des variables specifiques au job #
###################################################

REP_LOG=${REP}/logs
FILE_LOG=${REP_LOG}/${DESC}-${DATE}.log

CODEAPP=Q04

#######################
##LANCEMENT DU SCRIPT##
#######################
#-------------------------------------------------------------------
# Debut du job
#-------------------------------------------------------------------
echo "----------------------------------------------------------------------------------------------------------"
echo "----------------------------------------------------------------------------------------------------------"
echo ""
echo "#### DEBUT JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
echo ""

sql_execute ()
{

sqlplus -s /nolog <<EOF > ${FILE_LOG}
connect $EXE_PARM

/* FERMAT BATCH - $DESC - Script generated on 06/10/2004 17:13:07 */
execute $PROC;
exit

quit
EOF
}

sql_before ()
{

sqlplus -s /nolog <<EOF > ${FILE_LOG}
connect $EXE_PARM
/* FERMAT BATCH - $DESC - Script generated on 06/10/2004 17:13:07 */
execute $PROC_BEFORE('20${ODATE}'); $PROC;
exit

quit
EOF
}


verif_apres_proc()
{
# ---------------------------------------------------------------------------- #
# Information sur le fichier de sortie (avant lancement de la procedure)
# ---------------------------------------------------------------------------- #
# On verifie existance du fichier genere
if [ -s ${FILE_LOG} ]; then
        echo "Information sur le repertoire ${REP_LOG}"
        echo "`ls -dl ${REP_LOG}`"
        echo ""
        echo "Information sur le fichier ${DESC}-${DATE}.log"
        echo "Le fichier ${FILE_LOG} existe et n'est pas vide"
        echo "`ls -ltr ${DESC}-${DATE}.log`"
                else
                echo "Information sur le repertoire ${REP_LOG}"
                echo "`ls -dl ${REP_LOG}`"
                echo ""
                echo "Information sur le fichier ${DESC}-${DATE}.log"
                echo "Le fichier ${FILE_LOG} est vide ou n'existe pas"
                echo "`ls -ltr ${DESC}-${DATE}.log`"
                echo ""
                echo "#### FIN JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
                echo "exit 1"
                exit 1
fi


# On verifie qu'il n'y a pas d'erreur ORACLE
if [ `/bin/grep ERROR ${FILE_LOG} | wc -l` -gt 0 ] || [ `/bin/grep SP2-0640 ${FILE_LOG} | wc -l` -gt 0 ]; then
  echo ""
  echo "PLANTAGE DE LA PROCEDURE AVEC L'ERREUR SUIVANTE : "
  echo ""
  echo "`cat ${FILE_LOG}`"
  echo "**********************************************************************************************************"
  echo ""
  echo "#### FIN JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
  echo "exit 2"
  exit 2
        else
        echo ""
        echo "**********************************************************************************************************"
        echo "PAS D'ERREUR DANS LE FICHIER ${FILE_LOG} DE LA PROCEDURE"
        echo "**********************************************************************************************************"
fi

}


#Main
echo "VARIABLES CTLM"
echo "PROC=${PROC}"
echo "DESC=${DESC}"
echo "SQLE=${SQLE}"
echo "REP=${REP}"
echo "PROC_BEFORE=${PROC_BEFORE}"
echo "CONTEXTE=${CONTEXTE}"
echo ""
echo "VARIABLES VALORISEES DANS LE SCRIPT"
echo "GENERAL_ENV=${GENERAL_ENV}"
echo "LOCAL_ENV=${LOCAL_ENV}"
echo "REP_LOG=${REP_LOG}"
echo "FILE_LOG=${FILE_LOG}"
echo ""

cd ${REP_LOG}

echo ""
echo "**********************************************************************************************************"

if [ $CONTEXTE == O ]; then
        echo "Le $(date "+%Y%m%d a %Hh%Mm%Ss") : LANCEMENT DES PROCEDURES SQL $PROC_BEFORE('20${ODATE}') et ${PROC}"
        sql_before
                else
                echo "Le $(date "+%Y%m%d a %Hh%Mm%Ss") : LANCEMENT DE LA PROCEDURE SQL ${PROC}"
                $SQLE
fi

echo ""
echo "**********************************************************************************************************"
echo "Le $(date "+%Y%m%d a %Hh%Mm%Ss") : VERIFICATION APRES LANCEMENT PROCEDURE SQL"
echo ""
verif_apres_proc


echo ""
echo "#### FIN JOB ${CTM0} $(date "+%Y%m%d-%H%M%S") ####"
#-------------------------------------------------------------------
# Fin du job proprement dit
#-------------------------------------------------------------------
echo "exit ${?}"
exit ${?}


